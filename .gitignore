# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
*.so
.coverage
coverage.xml

# Rust
target/
Cargo.lock

# Virtual environments
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Database cache
*.db
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db

# Benchmark outputs
benchmarks/results/

# Claude Code — local settings, worktrees, session state
.claude/

# Secrets / local environment (e.g. OPENAI_API_KEY for tree-reasoning runs)
.env
.env.*
!.env.example

# Benchmark per-sample eval DB cache (index-once, reuse across sweeps)
benchmarks/.eval_cache/
# Vector index sidecars — TurboQuant dense (.tq) + fast-plaid multi-vector (.plaid).
# Binary generated artifacts; never commit (mirrors the *.db rule above).
*.tq
*.plaid
