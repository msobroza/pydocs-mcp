# Copy to `.env` (which is gitignored) and fill in your values, then load it
# before benchmark runs that call the LLM:
#
#     cp .env.example .env
#     set -a; source .env; set +a
#
# See benchmarks/EXPERIMENTS.md.

# OpenAI API key. Required only for the tree-reasoning experiment configs
# (benchmarks/configs/repoqa_tree.yaml, repoqa_hybrid_tree.yaml), and for
# OpenAI embeddings if you set `embedding.provider: openai`. Read directly
# from the environment by the OpenAI SDK; BM25 / dense / hybrid runs don't
# need it.
OPENAI_API_KEY=sk-your-key-here

# This file only covers the benchmark-run variable above.
#
# - Server / retrieval config overrides (ranking weights, embedder identity,
#   output limits, ...) go through PYDOCS_* env vars layered over AppConfig,
#   plus PYDOCS_CONFIG_PATH to point at a YAML overlay — see
#   DOCUMENTATION.md's "Configuration" section.
# - The `ask-your-docs` extra reads its own connection settings from the
#   environment (workspace path, model, API base URL, config overlay) — see
#   `pydocs_mcp/ask_your_docs/cli.py` for the current variable names.
